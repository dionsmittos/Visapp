# Environment variables (copy to .env for local config)

# API Configuration
VITE_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
VITE_OVERPASS_TIMEOUT=25000

# Map Configuration
VITE_MAP_CENTER_LAT=52.0000
VITE_MAP_CENTER_LNG=4.3700
VITE_INITIAL_ZOOM=11

# Tile Layer (OSM)
VITE_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors
